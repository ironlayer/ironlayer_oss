# =============================================================================
# IronLayer Frontend — Environment Variables
# =============================================================================
#
# Copy to .env and customise. Vite requires the VITE_ prefix.
#
#   cp .env.example .env
#
# =============================================================================

# API origin (scheme + host + port). Do NOT include /api/v1 — that is
# appended automatically in client.ts.  Leave blank or unset to use
# same-origin requests (works when frontend and API share a domain or proxy).
#
# Examples:
#   Development:  http://localhost:8000
#   Production:   https://app.ironlayer.app   (if API is same-origin)
#   Cross-origin: https://api.ironlayer.app   (if API is separate domain)
VITE_API_URL=http://localhost:8000

# Environment label (dev | staging | production).
VITE_ENVIRONMENT=dev

# Error reporting endpoint — REQUIRED for production error visibility (BL-114).
# Without this, uncaught errors and React ErrorBoundary catches are logged to
# the browser console only, making production incidents invisible to the team.
#
# The value should be an HTTPS URL accepting POST with JSON body:
#   { name, message, stack, componentStack, url, userAgent, timestamp }
#
# Examples:
#   Sentry relay:     https://o123.ingest.sentry.io/api/456/envelope/
#   Custom collector: https://errors.yourdomain.com/collect
#   Datadog RUM:      https://browser-intake-datadoghq.com/api/v2/rum
#
# When unset, errors are logged to the browser console only (dev-mode default).
# VITE_ERROR_REPORTING_URL=https://errors.ironlayer.app/collect
